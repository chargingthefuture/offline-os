{
  "name": "Offline OS",
  "short_name": "OS",
  "description": "Personal offline-first dashboard and app launcher",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#16171b",
  "theme_color": "#16171b",
  "icons": [
    { "src": "shared/icons/icon-192.png", "sizes": "192x192", "type": "image/png" },
    { "src": "shared/icons/icon-512.png", "sizes": "512x512", "type": "image/png" },
    { "src": "shared/icons/icon.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any maskable" }
  ]
}
